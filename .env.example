# ── Anthropic (Claude API) ─────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Firecrawl (Web Scraping) ───────────────────────────────────────
# Get from: https://www.firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ── Voyage AI (Embeddings) ─────────────────────────────────────────
# Get from: https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=your_voyage_api_key_here

# ── Twilio (WhatsApp Gateway) ──────────────────────────────────────
# Get from: https://www.twilio.com/console → Account Info
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Sandbox number (use as-is for POC testing)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── App Config ─────────────────────────────────────────────────────
VOYAGE_MODEL=voyage-finance-2
CLAUDE_MODEL=claude-sonnet-4-6
CHROMA_DB_PATH=./data/chroma_db
RAW_DATA_PATH=./data/raw
TOP_K_RESULTS=3
SESSION_TIMEOUT_MINUTES=30
HISTORY_MAX_TURNS=25
